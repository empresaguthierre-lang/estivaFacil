<%= form_with model: product, class: "grid gap-5" do |form| %>
  <% if product.errors.any? %>
    <div class="rounded-lg border border-red-700 bg-red-950 p-4 text-red-100">
      <p class="font-semibold">Revise o cadastro:</p>
      <ul class="mt-2 list-disc pl-5">
        <% product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 rounded-lg border border-[#334155] bg-[#111827] p-5 md:grid-cols-3">
    <div>
      <%= form.label :internal_code, "ID interno", class: "mb-1 block text-sm text-[#94A3B8]" %>
      <%= form.text_field :internal_code, class: "w-full rounded-md border border-[#334155] bg-[#0F172A] px-3 py-2 text-[#F8FAFC]" %>
    </div>
    <div>
      <%= form.label :sku, "SKU", class: "mb-1 block text-sm text-[#94A3B8]" %>
      <%= form.text_field :sku, class: "w-full rounded-md border border-[#334155] bg-[#0F172A] px-3 py-2 text-[#F8FAFC]" %>
    </div>
    <div>
      <%= form.label :reference_code, "Referência", class: "mb-1 block text-sm text-[#94A3B8]" %>
      <%= form.text_field :reference_code, class: "w-full rounded-md border border-[#334155] bg-[#0F172A] px-3 py-2 text-[#F8FAFC]" %>
    </div>
    <div class="md:col-span-2">
      <%= form.label :name, "Produto", class: "mb-1 block text-sm text-[#94A3B8]" %>
      <%= form.text_field :name, required: true, class: "w-full rounded-md border border-[#334155] bg-[#0F172A] px-3 py-2 text-[#F8FAFC]" %>
    </div>
    <div>
      <%= form.label :default_count_method, "Método padrão", class: "mb-1 block text-sm text-[#94A3B8]" %>
      <%= form.select :default_count_method, Product::COUNT_METHODS.map { |method| [method.humanize, method] }, {}, class: "w-full rounded-md border border-[#334155] bg-[#0F172A] px-3 py-2 text-[#F8FAFC]" %>
    </div>
    <div class="md:col-span-3">
      <%= form.label :description, "Descrição", class: "mb-1 block text-sm text-[#94A3B8]" %>
      <%= form.text_area :description, rows: 3, class: "w-full rounded-md border border-[#334155] bg-[#0F172A] px-3 py-2 text-[#F8FAFC]" %>
    </div>
  </div>

  <div class="grid gap-4 rounded-lg border border-[#334155] bg-[#111827] p-5 md:grid-cols-4">
    <div>
      <%= form.label :package_label, "Tipo de embalagem", class: "mb-1 block text-sm text-[#94A3B8]" %>
      <%= form.text_field :package_label, placeholder: "caixa, fardo, pacote, tambor...", class: "w-full rounded-md border border-[#334155] bg-[#0F172A] px-3 py-2 text-[#F8FAFC]" %>
    </div>
    <div>
      <%= form.label :units_per_package, "Unidades por embalagem", class: "mb-1 block text-sm text-[#94A3B8]" %>
      <%= form.number_field :units_per_package, min: 1, class: "w-full rounded-md border border-[#334155] bg-[#0F172A] px-3 py-2 text-[#F8FAFC]" %>
    </div>
    <div>
      <%= form.label :packages_per_pallet, "Embalagens por palete", class: "mb-1 block text-sm text-[#94A3B8]" %>
      <%= form.number_field :packages_per_pallet, min: 1, class: "w-full rounded-md border border-[#334155] bg-[#0F172A] px-3 py-2 text-[#F8FAFC]" %>
    </div>
    <div>
      <%= form.label :package_box_id, "Embalagem cadastrada", class: "mb-1 block text-sm text-[#94A3B8]" %>
      <%= form.collection_select :package_box_id, @package_boxes, :id, :name, { prompt: "Opcional" }, class: "w-full rounded-md border border-[#334155] bg-[#0F172A] px-3 py-2 text-[#F8FAFC]" %>
    </div>
  </div>

  <div class="grid gap-4 rounded-lg border border-[#334155] bg-[#111827] p-5 md:grid-cols-3">
    <h2 class="text-lg font-semibold text-[#F8FAFC] md:col-span-3">Pesos e medidas</h2>
    <div>
      <%= form.label :unit_weight_kg, "Peso da unidade kg", class: "mb-1 block text-sm text-[#94A3B8]" %>
      <%= form.number_field :unit_weight_kg, step: 0.001, class: "w-full rounded-md border border-[#334155] bg-[#0F172A] px-3 py-2 text-[#F8FAFC]" %>
    </div>
    <div>
      <%= form.label :package_weight_kg, "Peso da embalagem kg", class: "mb-1 block text-sm text-[#94A3B8]" %>
      <%= form.number_field :package_weight_kg, step: 0.001, class: "w-full rounded-md border border-[#334155] bg-[#0F172A] px-3 py-2 text-[#F8FAFC]" %>
    </div>
    <div>
      <%= form.label :pallet_weight_kg, "Peso do palete kg", class: "mb-1 block text-sm text-[#94A3B8]" %>
      <%= form.number_field :pallet_weight_kg, step: 0.001, class: "w-full rounded-md border border-[#334155] bg-[#0F172A] px-3 py-2 text-[#F8FAFC]" %>
    </div>

    <% [ [ "Unidade", :unit ], [ "Embalagem", :package ], [ "Palete", :pallet ] ].each do |label, prefix| %>
      <div class="rounded-lg border border-[#334155] bg-[#0F172A] p-4">
        <h3 class="font-semibold text-[#F8FAFC]"><%= label %></h3>
        <div class="mt-3 grid gap-3">
          <%= form.number_field :"#{prefix}_length_cm", step: 0.01, placeholder: "Comprimento cm", class: "w-full rounded-md border border-[#334155] bg-[#111827] px-3 py-2 text-[#F8FAFC]" %>
          <%= form.number_field :"#{prefix}_width_cm", step: 0.01, placeholder: "Largura cm", class: "w-full rounded-md border border-[#334155] bg-[#111827] px-3 py-2 text-[#F8FAFC]" %>
          <%= form.number_field :"#{prefix}_height_cm", step: 0.01, placeholder: "Altura cm", class: "w-full rounded-md border border-[#334155] bg-[#111827] px-3 py-2 text-[#F8FAFC]" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="grid gap-4 rounded-lg border border-[#334155] bg-[#111827] p-5 md:grid-cols-3">
    <label class="flex items-center gap-2 text-sm text-[#F8FAFC]"><%= form.check_box :stackable %> Pode empilhar?</label>
    <div>
      <%= form.label :max_stack_layers, "Máximo de camadas", class: "mb-1 block text-sm text-[#94A3B8]" %>
      <%= form.number_field :max_stack_layers, min: 1, class: "w-full rounded-md border border-[#334155] bg-[#0F172A] px-3 py-2 text-[#F8FAFC]" %>
    </div>
    <label class="flex items-center gap-2 text-sm text-[#F8FAFC]"><%= form.check_box :fragile %> Produto frágil?</label>
    <label class="flex items-center gap-2 text-sm text-[#F8FAFC]"><%= form.check_box :can_rotate %> Pode girar?</label>
    <label class="flex items-center gap-2 text-sm text-[#F8FAFC]"><%= form.check_box :hazardous %> Produto perigoso?</label>
    <label class="flex items-center gap-2 text-sm text-[#F8FAFC]"><%= form.check_box :active %> Ativo</label>
  </div>

  <div class="flex gap-3">
    <%= form.submit "Salvar produto", class: "rounded-md bg-[#10B981] px-4 py-2 font-semibold text-[#06131E] hover:bg-[#059669]" %>
    <%= link_to "Cancelar", products_path, class: "rounded-md border border-[#334155] bg-[#1F2937] px-4 py-2 text-white hover:bg-[#334155]" %>
  </div>
<% end %>
