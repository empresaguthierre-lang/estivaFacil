<%= form_with model: vehicle, class: "grid gap-5" do |form| %>
  <% if vehicle.errors.any? %>
    <div class="rounded border border-red-700 bg-red-950 p-4 text-red-100">
      <p class="font-semibold">Revise o cadastro:</p>
      <ul class="mt-2 list-disc pl-5">
        <% vehicle.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 rounded border border-zinc-800 bg-zinc-900 p-5 md:grid-cols-3">
    <div>
      <%= form.label :name, "Nome", class: "mb-1 block text-sm text-zinc-300" %>
      <%= form.text_field :name, required: true, class: "w-full rounded border border-zinc-700 bg-zinc-950 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :kind, "Tipo", class: "mb-1 block text-sm text-zinc-300" %>
      <%= form.text_field :kind, required: true, class: "w-full rounded border border-zinc-700 bg-zinc-950 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :max_weight_kg, "Peso máximo kg", class: "mb-1 block text-sm text-zinc-300" %>
      <%= form.number_field :max_weight_kg, step: 0.01, required: true, class: "w-full rounded border border-zinc-700 bg-zinc-950 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :max_volume_m3, "Volume máximo m³", class: "mb-1 block text-sm text-zinc-300" %>
      <%= form.number_field :max_volume_m3, step: 0.001, required: true, class: "w-full rounded border border-zinc-700 bg-zinc-950 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :length_cm, "Comprimento cm", class: "mb-1 block text-sm text-zinc-300" %>
      <%= form.number_field :length_cm, step: 0.01, required: true, class: "w-full rounded border border-zinc-700 bg-zinc-950 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :width_cm, "Largura cm", class: "mb-1 block text-sm text-zinc-300" %>
      <%= form.number_field :width_cm, step: 0.01, required: true, class: "w-full rounded border border-zinc-700 bg-zinc-950 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :height_cm, "Altura cm", class: "mb-1 block text-sm text-zinc-300" %>
      <%= form.number_field :height_cm, step: 0.01, required: true, class: "w-full rounded border border-zinc-700 bg-zinc-950 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :pallet_capacity, "Capacidade em paletes", class: "mb-1 block text-sm text-zinc-300" %>
      <%= form.number_field :pallet_capacity, min: 1, class: "w-full rounded border border-zinc-700 bg-zinc-950 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :body_type, "Tipo de carroceria", class: "mb-1 block text-sm text-zinc-300" %>
      <%= form.text_field :body_type, placeholder: "Baú, sider, graneleiro...", class: "w-full rounded border border-zinc-700 bg-zinc-950 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :usable_length_cm, "Comprimento útil cm", class: "mb-1 block text-sm text-zinc-300" %>
      <%= form.number_field :usable_length_cm, step: 0.01, class: "w-full rounded border border-zinc-700 bg-zinc-950 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :usable_width_cm, "Largura útil cm", class: "mb-1 block text-sm text-zinc-300" %>
      <%= form.number_field :usable_width_cm, step: 0.01, class: "w-full rounded border border-zinc-700 bg-zinc-950 px-3 py-2" %>
    </div>
    <div>
      <%= form.label :usable_height_cm, "Altura útil cm", class: "mb-1 block text-sm text-zinc-300" %>
      <%= form.number_field :usable_height_cm, step: 0.01, class: "w-full rounded border border-zinc-700 bg-zinc-950 px-3 py-2" %>
    </div>
    <label class="flex items-center gap-2 text-sm text-zinc-300">
      <%= form.check_box :allows_hazardous %>
      Permite carga perigosa
    </label>
    <label class="flex items-center gap-2 text-sm text-zinc-300">
      <%= form.check_box :refrigerated %>
      Refrigerado
    </label>
    <label class="flex items-center gap-2 text-sm text-zinc-300">
      <%= form.check_box :active %>
      Ativo
    </label>
    <div class="md:col-span-3">
      <%= form.label :notes, "Observações", class: "mb-1 block text-sm text-zinc-300" %>
      <%= form.text_area :notes, rows: 3, class: "w-full rounded border border-zinc-700 bg-zinc-950 px-3 py-2" %>
    </div>
  </div>

  <div class="flex gap-3">
    <%= form.submit "Salvar veículo", class: "rounded bg-emerald-500 px-4 py-2 font-semibold text-zinc-950 hover:bg-emerald-400" %>
    <%= link_to "Cancelar", vehicles_path, class: "rounded bg-zinc-800 px-4 py-2 text-white hover:bg-zinc-700" %>
  </div>
<% end %>
