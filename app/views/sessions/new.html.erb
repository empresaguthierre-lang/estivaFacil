<section class="mx-auto grid max-w-md gap-6 rounded-lg border border-[#1E294B] bg-[#131B2E]/50 p-8 shadow-2xl shadow-slate-950/50 backdrop-blur-md mt-12">
  <div class="flex flex-col items-center text-center">
    <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-emerald-400 to-teal-500 text-[#06131E] shadow-lg shadow-emerald-500/20 mb-4">
      <%= lucide_icon(:warehouse, css: "h-6 w-6") %>
    </span>
    <h1 class="text-2xl font-bold tracking-tight text-[#F8FAFC]">Entrar no EstivaFácil</h1>
    <p class="mt-1.5 text-xs text-[#94A3B8]">Acesse sua empresa para calcular cubagem, estiva e veículo ideal.</p>
  </div>

  <%= form_with url: session_path, class: "grid gap-5" do |form| %>
    <div>
      <%= form.label :email, "E-mail", class: "mb-1.5 block text-xs font-semibold text-slate-300" %>
      <%= form.email_field :email, required: true, autofocus: true, placeholder: "seu@email.com", class: "w-full rounded-md border border-[#1E294B] bg-[#090D16] px-3.5 py-2.5 text-sm text-[#F8FAFC] placeholder-slate-600 outline-none transition focus:border-emerald-500/40 focus:ring-2 focus:ring-emerald-500/20" %>
    </div>

    <div>
      <%= form.label :password, "Senha", class: "mb-1.5 block text-xs font-semibold text-slate-300" %>
      <%= form.password_field :password, required: true, placeholder: "••••••••", class: "w-full rounded-md border border-[#1E294B] bg-[#090D16] px-3.5 py-2.5 text-sm text-[#F8FAFC] placeholder-slate-600 outline-none transition focus:border-emerald-500/40 focus:ring-2 focus:ring-emerald-500/20" %>
    </div>

    <%= form.submit "Entrar no sistema", class: "w-full rounded-md bg-gradient-to-r from-emerald-600 to-teal-500 py-2.5 text-sm font-semibold text-[#06131E] shadow-md shadow-emerald-950/20 transition-all hover:from-emerald-500 hover:to-teal-400 hover:scale-[1.01] focus:outline-none focus:ring-2 focus:ring-emerald-500/40 cursor-pointer" %>
  <% end %>
</section>
