<section class="grid gap-6">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <div class="flex items-center gap-2">
        <% if @package_box.active? %>
          <span class="inline-flex items-center gap-1 rounded-full bg-emerald-500/10 px-2.5 py-0.5 text-xs font-semibold text-emerald-400 ring-1 ring-emerald-500/20">Ativa</span>
        <% else %>
          <span class="inline-flex items-center gap-1 rounded-full bg-red-500/10 px-2.5 py-0.5 text-xs font-semibold text-red-400 ring-1 ring-red-500/20">Inativa</span>
        <% end %>
      </div>
      <h1 class="mt-1 text-2xl font-bold tracking-tight text-[#F8FAFC]"><%= @package_box.name %></h1>
    </div>
    <div class="flex gap-3">
      <%= link_to edit_package_box_path(@package_box), class: "inline-flex items-center gap-2 rounded-md bg-gradient-to-r from-emerald-600 to-teal-500 px-4 py-2 text-sm font-semibold text-[#06131E] shadow-md shadow-emerald-950/20 transition-all hover:from-emerald-500 hover:to-teal-400 hover:scale-[1.02]" do %>
        <%= lucide_icon(:edit, css: "h-4 w-4") %>
        Editar
      <% end %>
      <%= link_to package_boxes_path, class: "rounded-md border border-[#1E294B] bg-[#131B2E] px-4 py-2 text-sm font-semibold text-slate-300 transition hover:bg-[#1E294B] hover:text-white" do %>
        Voltar
      <% end %>
    </div>
  </div>

  <dl class="grid gap-4 rounded-lg border border-[#1E294B] bg-[#131B2E]/40 p-5 md:grid-cols-4 shadow-xl shadow-slate-950/20 backdrop-blur-md">
    <div>
      <dt class="text-xs text-[#94A3B8]">Comprimento</dt>
      <dd class="mt-1 font-semibold text-[#F8FAFC] font-mono"><%= @package_box.length_cm %> cm</dd>
    </div>
    <div>
      <dt class="text-xs text-[#94A3B8]">Largura</dt>
      <dd class="mt-1 font-semibold text-[#F8FAFC] font-mono"><%= @package_box.width_cm %> cm</dd>
    </div>
    <div>
      <dt class="text-xs text-[#94A3B8]">Altura</dt>
      <dd class="mt-1 font-semibold text-[#F8FAFC] font-mono"><%= @package_box.height_cm %> cm</dd>
    </div>
    <div>
      <dt class="text-xs text-[#94A3B8]">Volume útil</dt>
      <dd class="mt-1 font-semibold text-teal-400 font-mono"><%= number_with_precision(@package_box.volume_m3, precision: 3) %> m³</dd>
    </div>
    <div>
      <dt class="text-xs text-[#94A3B8]">Unidades por caixa</dt>
      <dd class="mt-1 font-semibold text-[#F8FAFC]"><%= @package_box.units_per_package %> un</dd>
    </div>
    <div>
      <dt class="text-xs text-[#94A3B8]">Peso da embalagem</dt>
      <dd class="mt-1 font-semibold text-[#F8FAFC] font-mono"><%= number_with_precision(@package_box.package_weight_kg, precision: 2) %> kg</dd>
    </div>
  </dl>
</section>
