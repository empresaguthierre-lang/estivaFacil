<section class="grid gap-6">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="inline-flex items-center gap-1.5 text-xs font-semibold text-emerald-400">
        <%= lucide_icon(:package, css: "h-3.5 w-3.5") %>
        Módulo de Cadastros
      </p>
      <h1 class="mt-1 text-2xl font-bold tracking-tight text-[#F8FAFC]">Produtos</h1>
      <p class="mt-1 text-xs text-[#94A3B8]">Pesquise por nome, SKU, referência ou código comercial.</p>
    </div>
    <%= link_to new_product_path, class: "inline-flex items-center gap-2 rounded-md bg-gradient-to-r from-emerald-600 to-teal-500 px-4 py-2 font-semibold text-[#06131E] shadow-md shadow-emerald-950/20 transition-all hover:from-emerald-500 hover:to-teal-400 hover:scale-[1.02]" do %>
      <%= lucide_icon(:plus, css: "h-4 w-4") %>
      Novo produto
    <% end %>
  </div>

  <%= form_with url: products_path, method: :get, class: "flex gap-3" do |form| %>
    <div class="relative w-full">
      <span class="absolute inset-y-0 left-3 flex items-center text-slate-500">
        <%= lucide_icon(:search, css: "h-4 w-4") %>
      </span>
      <%= form.search_field :q, value: params[:q], placeholder: "Buscar produto, SKU ou referência...", class: "w-full rounded-md border border-[#1E294B] bg-[#131B2E]/60 py-2.5 pl-10 pr-4 text-sm text-[#F8FAFC] placeholder-slate-500 outline-none transition focus:border-emerald-500/40 focus:ring-2 focus:ring-emerald-500/20" %>
    </div>
    <%= form.submit "Pesquisar", class: "rounded-md border border-[#1E294B] bg-[#131B2E] px-5 py-2.5 text-sm font-semibold text-[#F8FAFC] transition hover:bg-[#1E294B] hover:text-white" %>
  <% end %>

  <div class="overflow-hidden rounded-lg border border-[#1E294B] bg-[#131B2E]/40 backdrop-blur-md">
    <div class="overflow-x-auto">
      <table class="w-full min-w-[980px] text-left text-sm">
        <thead class="bg-[#090D16]/50 text-xs uppercase text-[#94A3B8] border-b border-[#1E294B]">
          <tr>
            <th class="px-5 py-3 font-semibold">Produto</th>
            <th class="px-5 py-3 font-semibold">SKU</th>
            <th class="px-5 py-3 font-semibold">Referência</th>
            <th class="px-5 py-3 font-semibold">Método</th>
            <th class="px-5 py-3 font-semibold">Embalagem</th>
            <th class="px-5 py-3 font-semibold">Un./emb.</th>
            <th class="px-5 py-3 font-semibold">Emb./palete</th>
            <th class="px-5 py-3 font-semibold">Peso</th>
            <th class="px-5 py-3 font-semibold">Regras</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[#1E294B]/60">
          <% @products.each do |product| %>
            <tr class="transition-colors duration-150 hover:bg-[#1E294B]/20">
              <td class="px-5 py-4">
                <%= link_to product.name, product, class: "font-semibold text-[#F8FAFC] hover:text-emerald-400 transition-colors" %>
                <p class="text-xs text-slate-500">ID: <%= product.commercial_code.presence || "-" %></p>
              </td>
              <td class="px-5 py-4 text-[#94A3B8] font-mono text-xs"><%= product.sku.presence || "-" %></td>
              <td class="px-5 py-4 text-[#94A3B8] font-mono text-xs"><%= product.reference_code.presence || product.ref_code.presence || "-" %></td>
              <td class="px-5 py-4 text-[#F8FAFC]"><%= product.default_count_method.humanize %></td>
              <td class="px-5 py-4 text-[#94A3B8] font-medium"><%= product.package_name.presence || "-" %></td>
              <td class="px-5 py-4 text-[#94A3B8]"><%= product.units_per_package.presence || "-" %></td>
              <td class="px-5 py-4 text-[#94A3B8]"><%= product.packages_per_pallet.presence || "-" %></td>
              <td class="px-5 py-4 text-[#F8FAFC] font-medium"><%= number_with_precision(product.package_weight_kg || product.unit_weight_kg || product.weight_per_unit_kg, precision: 3) %> kg</td>
              <td class="px-5 py-4">
                <div class="flex flex-wrap gap-1">
                  <% if product.stackable? %>
                    <span class="rounded-full bg-emerald-500/10 px-2 py-0.5 text-2xs font-semibold text-emerald-400 ring-1 ring-emerald-500/20">Empilhável</span>
                  <% else %>
                    <span class="rounded-full bg-slate-500/10 px-2 py-0.5 text-2xs font-semibold text-slate-400 ring-1 ring-slate-500/10">Não empilhável</span>
                  <% end %>
                  <% if product.fragile? %>
                    <span class="rounded-full bg-amber-500/10 px-2 py-0.5 text-2xs font-semibold text-amber-400 ring-1 ring-amber-500/20">Frágil</span>
                  <% end %>
                  <% if product.hazardous? %>
                    <span class="rounded-full bg-red-500/10 px-2 py-0.5 text-2xs font-semibold text-red-400 ring-1 ring-red-500/20">Perigoso</span>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</section>
